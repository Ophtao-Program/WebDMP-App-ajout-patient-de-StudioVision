{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "commonjs",
    "lib":               ["ES2020"],
    "outDir":            "./dist",
    "rootDir":           "./src",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "resolveJsonModule": true,
    "sourceMap":         true
  },
  "include": ["src/main.ts", "src/preload.ts", "src/preload_dmp.ts", "src/preload_quick.ts", "src/doctypes.ts"],
  "exclude": ["src/renderer", "node_modules", "dist"]
}
