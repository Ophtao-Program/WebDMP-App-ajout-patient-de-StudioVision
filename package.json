{
  "name": "webdmp-app",
  "version": "1.0.0",
  "description": "Dépôt de documents StudioVision vers le DMP (Mon Espace Santé) via Pro Santé Connect",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && tsc -p src/renderer/tsconfig.json",
    "start": "npm run build && electron .",
    "service": "npm run build && electron . --service",
    "dev": "tsc --watch & tsc -p src/renderer/tsconfig.json --watch & electron ."
  },
